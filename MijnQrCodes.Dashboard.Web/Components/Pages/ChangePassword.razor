@page "/change-password"
@using System.Security.Claims
@using MediatR
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using MijnQrCodes.Contracts.Auth
@inject IMediator Mediator
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Wachtwoord wijzigen - MijnQrCodes</PageTitle>

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh;">
    <div style="width: 100%; max-width: 400px; padding: 2rem;">
        <h3 style="text-align: center; margin-bottom: 1.5rem;">
            <span>🔑</span> Wachtwoord wijzigen
        </h3>

        @if (_mustChange)
        {
            <div style="background: #fff3e0; color: #e65100; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                Je wachtwoord is gereset. Kies een nieuw wachtwoord om verder te gaan.
            </div>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <div style="background: #ffebee; color: #c62828; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                @_error
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleChange" FormName="ChangePasswordForm">
            <div style="margin-bottom: 1rem;">
                <label>Nieuw wachtwoord</label>
                <InputText @bind-Value="_model.NewPassword" type="password" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
            </div>
            <div style="margin-bottom: 1.5rem;">
                <label>Bevestig nieuw wachtwoord</label>
                <InputText @bind-Value="_model.ConfirmPassword" type="password" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
            </div>
            <button type="submit" style="width: 100%; padding: 0.75rem; background: #1976d2; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;">
                Wachtwoord wijzigen
            </button>
        </EditForm>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [SupplyParameterFromForm]
    private ChangePasswordFormModel _model { get; set; } = new();

    private string? _error;
    private bool _mustChange;
    private Guid _userId;

    private class ChangePasswordFormModel
    {
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    protected override void OnInitialized()
    {
        _model ??= new();
        var user = HttpContext?.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        _userId = Guid.Parse(user.FindFirstValue(ClaimTypes.NameIdentifier)!);
        _mustChange = user.FindFirstValue("MustChangePassword") == "True";
    }

    private async Task HandleChange()
    {
        if (string.IsNullOrWhiteSpace(_model.NewPassword))
        {
            _error = "Vul een nieuw wachtwoord in.";
            return;
        }

        if (_model.NewPassword.Length < 6)
        {
            _error = "Wachtwoord moet minimaal 6 tekens bevatten.";
            return;
        }

        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _error = "Wachtwoorden komen niet overeen.";
            return;
        }

        var success = await Mediator.Send(new ChangePasswordCommand
        {
            UserId = _userId,
            NewPassword = _model.NewPassword
        });

        if (!success)
        {
            _error = "Er is iets misgegaan. Probeer opnieuw.";
            return;
        }

        // Re-sign in with updated claims (MustChangePassword = false)
        var claims = new List<Claim>
        {
            new(ClaimTypes.NameIdentifier, _userId.ToString()),
            new(ClaimTypes.Name, HttpContext!.User.FindFirstValue(ClaimTypes.Name)!),
            new("MustChangePassword", "False")
        };

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        await HttpContext!.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal,
            new AuthenticationProperties { IsPersistent = true });

        Navigation.NavigateTo("/", forceLoad: true);
    }
}
