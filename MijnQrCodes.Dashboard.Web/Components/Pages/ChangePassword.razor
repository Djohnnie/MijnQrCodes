@page "/change-password"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Wachtwoord wijzigen - MijnQrCodes</PageTitle>

<div style="display: flex; justify-content: center; align-items: center; min-height: 100vh; padding: 2rem;">
    <MudPaper Elevation="0" Style="width: 100%; max-width: 400px; border: 1px solid var(--mud-palette-lines-default);"
              Class="pa-8 rounded-lg">
        <MudStack AlignItems="AlignItems.Center" Spacing="1" Class="mb-6">
            <MudAvatar Size="Size.Large" Style="background: linear-gradient(135deg, #f59e0b, #fbbf24); width: 56px; height: 56px;">
                <MudIcon Icon="@Icons.Material.Outlined.Key" Style="color: white; font-size: 1.8rem;" />
            </MudAvatar>
            <MudText Typo="Typo.h5" Class="mt-2">Wachtwoord wijzigen</MudText>
            <MudText Typo="Typo.body2" Color="Color.Tertiary">Kies een nieuw wachtwoord</MudText>
        </MudStack>

        @if (_mustChange)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Dense Class="mb-4"
                      Style="font-size: 0.85rem;">
                Je wachtwoord is gereset. Kies een nieuw wachtwoord om verder te gaan.
            </MudAlert>
        }

        @if (!string.IsNullOrEmpty(Error))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Text" Dense Class="mb-4"
                      Style="font-size: 0.85rem;">
                @Uri.UnescapeDataString(Error)
            </MudAlert>
        }

        <form method="post" action="/api/change-password">
            <MudStack Spacing="3">
                <div>
                    <MudText Typo="Typo.caption" Style="font-weight: 600;" Class="mb-1">Nieuw wachtwoord</MudText>
                    <input name="newPassword" type="password" autocomplete="new-password"
                           style="width: 100%; padding: 0.65rem 0.85rem; border: 1px solid var(--mud-palette-lines-default); border-radius: 8px; font-size: 0.9rem; background: transparent; color: var(--mud-palette-text-primary); outline: none;"
                           onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor=''" />
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="font-weight: 600;" Class="mb-1">Bevestig nieuw wachtwoord</MudText>
                    <input name="confirmPassword" type="password" autocomplete="new-password"
                           style="width: 100%; padding: 0.65rem 0.85rem; border: 1px solid var(--mud-palette-lines-default); border-radius: 8px; font-size: 0.9rem; background: transparent; color: var(--mud-palette-text-primary); outline: none;"
                           onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor=''" />
                </div>
                <button type="submit"
                        style="width: 100%; padding: 0.7rem; background: linear-gradient(135deg, #f59e0b, #fbbf24); color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 0.9rem; font-weight: 600; margin-top: 0.5rem;">
                    Wachtwoord wijzigen
                </button>
            </MudStack>
        </form>
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private bool _mustChange;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _mustChange = authState.User.FindFirst("MustChangePassword")?.Value == "True";
    }
}
