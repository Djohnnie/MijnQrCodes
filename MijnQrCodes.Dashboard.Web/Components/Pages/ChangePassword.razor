@page "/change-password"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Wachtwoord wijzigen - MijnQrCodes</PageTitle>

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh;">
    <div style="width: 100%; max-width: 400px; padding: 2rem;">
        <h3 style="text-align: center; margin-bottom: 1.5rem;">
            <span>🔑</span> Wachtwoord wijzigen
        </h3>

        @if (_mustChange)
        {
            <div style="background: #fff3e0; color: #e65100; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                Je wachtwoord is gereset. Kies een nieuw wachtwoord om verder te gaan.
            </div>
        }

        @if (!string.IsNullOrEmpty(Error))
        {
            <div style="background: #ffebee; color: #c62828; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                @Uri.UnescapeDataString(Error)
            </div>
        }

        <form method="post" action="/api/change-password">
            <div style="margin-bottom: 1rem;">
                <label>Nieuw wachtwoord</label>
                <input name="newPassword" type="password" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
            </div>
            <div style="margin-bottom: 1.5rem;">
                <label>Bevestig nieuw wachtwoord</label>
                <input name="confirmPassword" type="password" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
            </div>
            <button type="submit" style="width: 100%; padding: 0.75rem; background: #1976d2; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;">
                Wachtwoord wijzigen
            </button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private bool _mustChange;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _mustChange = authState.User.FindFirst("MustChangePassword")?.Value == "True";
    }
}
