@page "/register"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>Registreren - MijnQrCodes</PageTitle>

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh;">
    <div style="width: 100%; max-width: 400px; padding: 2rem;">
        <h3 style="text-align: center; margin-bottom: 1.5rem;">
            <span>📝</span> Registreren
        </h3>

        @if (Registered == "true")
        {
            <div style="background: #e8f5e9; color: #2e7d32; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                @if (AutoApproved == "true")
                {
                    <text>Account aangemaakt! Je kunt nu <a href="/login">aanmelden</a>.</text>
                }
                else
                {
                    <text>Account aangemaakt! Een beheerder moet je account eerst goedkeuren voordat je kunt aanmelden.</text>
                }
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Error))
            {
                <div style="background: #ffebee; color: #c62828; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                    @Uri.UnescapeDataString(Error)
                </div>
            }

            <form method="post" action="/api/register">
                <div style="margin-bottom: 1rem;">
                    <label>Gebruikersnaam</label>
                    <input name="username" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
                </div>
                <div style="margin-bottom: 1rem;">
                    <label>Wachtwoord</label>
                    <input name="password" type="password" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label>Wachtwoord bevestigen</label>
                    <input name="confirmPassword" type="password" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
                </div>
                <button type="submit" style="width: 100%; padding: 0.75rem; background: #1976d2; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;">
                    Registreren
                </button>
            </form>

            <p style="text-align: center; margin-top: 1rem;">
                Al een account? <a href="/login">Aanmelden</a>
            </p>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "registered")]
    public string? Registered { get; set; }

    [SupplyParameterFromQuery(Name = "autoApproved")]
    public string? AutoApproved { get; set; }
}
