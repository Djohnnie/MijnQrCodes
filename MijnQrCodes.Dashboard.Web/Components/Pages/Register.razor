@page "/register"
@using MediatR
@using MijnQrCodes.Contracts.Auth
@inject IMediator Mediator

<PageTitle>Registreren - MijnQrCodes</PageTitle>

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh;">
    <div style="width: 100%; max-width: 400px; padding: 2rem;">
        <h3 style="text-align: center; margin-bottom: 1.5rem;">
            <span>📝</span> Registreren
        </h3>

        @if (_registered)
        {
            <div style="background: #e8f5e9; color: #2e7d32; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                @if (_autoApproved)
                {
                    <text>Account aangemaakt! Je kunt nu <a href="/login">aanmelden</a>.</text>
                }
                else
                {
                    <text>Account aangemaakt! Een beheerder moet je account eerst goedkeuren voordat je kunt aanmelden.</text>
                }
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_error))
            {
                <div style="background: #ffebee; color: #c62828; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                    @_error
                </div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleRegister" FormName="RegisterForm">
                <div style="margin-bottom: 1rem;">
                    <label>Gebruikersnaam</label>
                    <InputText @bind-Value="_model.Username" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
                </div>
                <div style="margin-bottom: 1rem;">
                    <label>Wachtwoord</label>
                    <InputText @bind-Value="_model.Password" type="password" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label>Wachtwoord bevestigen</label>
                    <InputText @bind-Value="_model.ConfirmPassword" type="password" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" />
                </div>
                <button type="submit" style="width: 100%; padding: 0.75rem; background: #1976d2; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;">
                    Registreren
                </button>
            </EditForm>

            <p style="text-align: center; margin-top: 1rem;">
                Al een account? <a href="/login">Aanmelden</a>
            </p>
        }
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private RegisterFormModel _model { get; set; } = new();

    private string? _error;
    private bool _registered;
    private bool _autoApproved;

    private class RegisterFormModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    private async Task HandleRegister()
    {
        _model ??= new();
        if (string.IsNullOrWhiteSpace(_model.Username) || string.IsNullOrWhiteSpace(_model.Password))
        {
            _error = "Vul alle velden in.";
            return;
        }

        if (_model.Password.Length < 6)
        {
            _error = "Wachtwoord moet minimaal 6 tekens bevatten.";
            return;
        }

        if (_model.Password != _model.ConfirmPassword)
        {
            _error = "Wachtwoorden komen niet overeen.";
            return;
        }

        var result = await Mediator.Send(new RegisterCommand
        {
            Username = _model.Username,
            Password = _model.Password
        });

        if (!result.Success)
        {
            _error = result.Error;
            return;
        }

        _registered = true;
        _autoApproved = result.AutoApproved;
    }
}
