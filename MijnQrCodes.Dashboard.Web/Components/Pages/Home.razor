@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using MediatR
@using MijnQrCodes.Contracts.ShortUrls
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>MijnQrCodes</PageTitle>

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4">Korte URL's</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog">Nieuwe URL</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary" />
    }
    else if (_shortUrls.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">Nog geen korte URL's aangemaakt.</MudAlert>
    }
    else
    {
        <MudGrid Spacing="4">
            @foreach (var item in _shortUrls)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="2">
                        <MudCardContent>
                            <MudText Typo="Typo.h6" Class="mb-1">@item.Title</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Primary" Class="mb-1" Style="word-break: break-all;">
                                /@item.ShortCode
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary" Style="word-break: break-all;">
                                @item.OriginalUrl
                            </MudText>
                            <MudText Typo="Typo.caption" Class="mt-2" Color="Color.Default">
                                Aangemaakt: @item.CreatedAt.ToString("dd-MM-yyyy HH:mm")
                            </MudText>
                        </MudCardContent>
                        <MudCardActions>
                            <MudIconButton Icon="@Icons.Material.Filled.QrCode2" Color="Color.Primary"
                                           OnClick="() => ShowQrCode(item)" aria-label="QR Code" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning"
                                           OnClick="() => OpenEditDialog(item)" aria-label="Bewerken" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           OnClick="() => ConfirmDelete(item)" aria-label="Verwijderen" />
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@if (_showQrDialog)
{
    <MudOverlay Visible="@_showQrDialog" OnClick="CloseQrDialog" DarkBackground ZIndex="1300">
        <MudCard Style="max-width: 520px; margin: auto;" @onclick:stopPropagation="true">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">QR Code - @_selectedItem?.Title</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseQrDialog" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="d-flex justify-center" Style="background: repeating-conic-gradient(#ddd 0% 25%, #fff 0% 50%) 50% / 20px 20px;">
                @if (_qrImageData is not null)
                {
                    <img src="data:image/png;base64,@Convert.ToBase64String(_qrImageData)" alt="QR Code"
                         style="width: 400px; height: 400px;" />
                }
                else
                {
                    <MudProgressCircular Indeterminate Color="Color.Primary" />
                }
            </MudCardContent>
            <MudCardContent>
                <MudGrid Spacing="2" Class="mt-2">
                    <MudItem xs="4">
                        <MudText Typo="Typo.caption" Class="mb-1">Achtergrond</MudText>
                        <MudColorPicker @bind-Value="_qrBackgroundColor" ColorPickerMode="ColorPickerMode.HEX"
                                        ShowAlpha="false" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudText Typo="Typo.caption" Class="mb-1">Voorgrond</MudText>
                        <MudColorPicker @bind-Value="_qrForegroundColor" ColorPickerMode="ColorPickerMode.HEX"
                                        ShowAlpha="false" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudText Typo="Typo.caption" Class="mb-1">Finder Pattern</MudText>
                        <MudColorPicker @bind-Value="_qrFinderColor" ColorPickerMode="ColorPickerMode.HEX"
                                        ShowAlpha="false" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth Class="mt-3"
                           OnClick="RefreshQrCode" StartIcon="@Icons.Material.Filled.Refresh">
                    Toepassen
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudOverlay>
}

@if (_showFormDialog)
{
    <MudOverlay Visible="@_showFormDialog" OnClick="CloseFormDialog" DarkBackground ZIndex="1300">
        <MudCard Style="max-width: 500px; margin: auto; min-width: 350px;" @onclick:stopPropagation="true">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@(_isEditing ? "URL Bewerken" : "Nieuwe URL")</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseFormDialog" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_formTitle" Label="Titel" Required RequiredError="Titel is verplicht"
                              Class="mb-3" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_formUrl" Label="URL" Required RequiredError="URL is verplicht"
                              Variant="Variant.Outlined" InputType="InputType.Url"
                              Placeholder="https://voorbeeld.be" />
            </MudCardContent>
            <MudCardActions Class="d-flex justify-end pa-4">
                <MudButton OnClick="CloseFormDialog" Class="mr-2">Annuleren</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveForm"
                           Disabled="@(string.IsNullOrWhiteSpace(_formTitle) || string.IsNullOrWhiteSpace(_formUrl))">
                    @(_isEditing ? "Opslaan" : "Aanmaken")
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudOverlay>
}

@code {
    private List<ShortUrlDto> _shortUrls = [];
    private bool _loading = true;

    private bool _showQrDialog;
    private ShortUrlDto? _selectedItem;
    private byte[]? _qrImageData;
    private MudColor _qrBackgroundColor = new("#FFFFFF");
    private MudColor _qrForegroundColor = new("#212121");
    private MudColor _qrFinderColor = new("#212121");

    private bool _showFormDialog;
    private bool _isEditing;
    private Guid _editingId;
    private string _formTitle = string.Empty;
    private string _formUrl = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        var response = await Mediator.Send(new GetShortUrlsQuery());
        _shortUrls = response.ShortUrls;
        _loading = false;
    }

    private void OpenCreateDialog()
    {
        _isEditing = false;
        _formTitle = string.Empty;
        _formUrl = string.Empty;
        _showFormDialog = true;
    }

    private void OpenEditDialog(ShortUrlDto item)
    {
        _isEditing = true;
        _editingId = item.Id;
        _formTitle = item.Title;
        _formUrl = item.OriginalUrl;
        _showFormDialog = true;
    }

    private void CloseFormDialog() => _showFormDialog = false;

    private async Task SaveForm()
    {
        if (string.IsNullOrWhiteSpace(_formTitle) || string.IsNullOrWhiteSpace(_formUrl)) return;

        if (_isEditing)
        {
            await Mediator.Send(new UpdateShortUrlCommand
            {
                Id = _editingId,
                Title = _formTitle,
                OriginalUrl = _formUrl
            });
            Snackbar.Add("URL bijgewerkt!", Severity.Success);
        }
        else
        {
            await Mediator.Send(new CreateShortUrlCommand
            {
                Title = _formTitle,
                OriginalUrl = _formUrl
            });
            Snackbar.Add("URL aangemaakt!", Severity.Success);
        }

        _showFormDialog = false;
        await LoadData();
    }

    private async Task ConfirmDelete(ShortUrlDto item)
    {
        var parameters = new DialogParameters<MessageBoxDialog>
        {
            { x => x.ContentText, $"Weet je zeker dat je '{item.Title}' wilt verwijderen?" },
            { x => x.YesText, "Verwijderen" },
            { x => x.CancelText, "Annuleren" }
        };

        var dialog = await DialogService.ShowAsync<MessageBoxDialog>("Verwijderen", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await Mediator.Send(new DeleteShortUrlCommand { Id = item.Id });
            Snackbar.Add("URL verwijderd!", Severity.Success);
            await LoadData();
        }
    }

    private async Task ShowQrCode(ShortUrlDto item)
    {
        _selectedItem = item;
        _qrImageData = null;
        _qrBackgroundColor = new("#FFFFFF");
        _qrForegroundColor = new("#212121");
        _qrFinderColor = new("#212121");
        _showQrDialog = true;

        await GenerateQrCode();
    }

    private async Task RefreshQrCode()
    {
        _qrImageData = null;
        StateHasChanged();
        await GenerateQrCode();
    }

    private async Task GenerateQrCode()
    {
        if (_selectedItem is null) return;

        var response = await Mediator.Send(new GetQrCodeQuery
        {
            Url = _selectedItem.OriginalUrl,
            BackgroundColor = _qrBackgroundColor.ToString(MudColorOutputFormats.Hex),
            ForegroundColor = _qrForegroundColor.ToString(MudColorOutputFormats.Hex),
            FinderPatternColor = _qrFinderColor.ToString(MudColorOutputFormats.Hex)
        });
        _qrImageData = response.ImageData;
        StateHasChanged();
    }

    private void CloseQrDialog()
    {
        _showQrDialog = false;
        _qrImageData = null;
    }
}
