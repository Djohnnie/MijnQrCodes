@page "/urls"
@using MediatR
@using MijnQrCodes.Contracts.ShortUrls
@using MijnQrCodes.Contracts.Tags
@using ApexCharts
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>URL's - MijnQrCodes</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudText Typo="Typo.h4">URL's</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg"
                   OnClick="OpenCreateDialog" Style="text-transform: none; font-weight: 600;">
            Nieuwe URL
        </MudButton>
    </MudStack>

    @if (_allTags.Count > 0)
    {
        <MudStack Row AlignItems="AlignItems.Center" Class="mb-4" Spacing="2" Wrap="Wrap.Wrap">
            <MudIcon Icon="@Icons.Material.Outlined.FilterAlt" Size="Size.Small" Color="Color.Tertiary" />
            <MudChipSet T="Guid" SelectionMode="SelectionMode.MultiSelection" SelectedValues="_selectedFilterTags" SelectedValuesChanged="OnFilterChanged">
                @foreach (var tag in _allTags)
                {
                    <MudChip T="Guid" Value="tag.Id"
                             Variant="@(_selectedFilterTags.Contains(tag.Id) ? Variant.Filled : Variant.Text)"
                             Style="@(_selectedFilterTags.Contains(tag.Id) ? $"background: {tag.Color}; color: white;" : $"border: 1px solid {tag.Color}; color: {tag.Color};")">
                        @tag.Name
                    </MudChip>
                }
            </MudChipSet>
        </MudStack>
    }

    @if (_loading)
    {
        <MudGrid Spacing="3">
            @for (var i = 0; i < 6; i++)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded-lg" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (_shortUrls.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-12 rounded-lg d-flex flex-column align-center"
                  Style="border: 2px dashed var(--mud-palette-lines-default);">
            <MudIcon Icon="@Icons.Material.Outlined.LinkOff" Size="Size.Large" Color="Color.Tertiary"
                     Style="font-size: 4rem;" />
            <MudText Typo="Typo.h6" Color="Color.Tertiary" Class="mt-4">Nog geen URL's</MudText>
            <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="mt-1 mb-4">
                Maak je eerste verkorte URL aan om te beginnen
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog" Style="text-transform: none; font-weight: 600;">
                Nieuwe URL
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var item in _filteredUrls)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="0" Class="rounded-lg url-card"
                              Style="border: 1px solid var(--mud-palette-lines-default); overflow: hidden; transition: all 0.2s ease;">
                        <div class="pa-4">
                            <MudStack Row AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                                <MudStack Spacing="1" Style="min-width: 0; flex: 1;">
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                        @item.Title
                                    </MudText>
                                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Outlined.Link" Size="Size.Small" Color="Color.Primary" />
                                        <MudLink Href="@($"{NavigationManager.BaseUri}r/{item.ShortCode}")" Target="_blank"
                                                 Typo="Typo.body2" Style="font-weight: 500;">
                                            /r/@item.ShortCode
                                        </MudLink>
                                    </MudStack>
                                </MudStack>
                                <div style="width: 48px; height: 48px; border-radius: 8px; overflow: hidden; flex-shrink: 0; background: @item.BackgroundColor; display: flex; align-items: center; justify-content: center; cursor: pointer;"
                                     @onclick="() => ShowQrCode(item)">
                                    <MudIcon Icon="@Icons.Material.Filled.QrCode2" Style="@($"color: {item.ForegroundColor}; font-size: 2rem;")" />
                                </div>
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-2"
                                     Style="word-break: break-all; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.OriginalUrl
                            </MudText>
                            @if (item.Tags.Count > 0)
                            {
                                <MudStack Row Spacing="1" Class="mt-2" Wrap="Wrap.Wrap">
                                    @foreach (var tag in item.Tags)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                                 Style="@($"border: 1px solid {tag.Color}; color: {tag.Color}; font-size: 0.7rem;")">
                                            @tag.Name
                                        </MudChip>
                                    }
                                </MudStack>
                            }
                            <MudDivider Class="my-3" />
                            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                    @item.CreatedAt.ToString("dd MMM yyyy")
                                </MudText>
                                <MudStack Row Spacing="0">
                                    <MudTooltip Text="QR Code">
                                        <MudIconButton Icon="@Icons.Material.Outlined.QrCode2" Size="Size.Small"
                                                       Color="Color.Primary" OnClick="() => ShowQrCode(item)" />
                                    </MudTooltip>
                                    <MudTooltip Text="Statistieken">
                                        <MudIconButton Icon="@Icons.Material.Outlined.BarChart" Size="Size.Small"
                                                       Color="Color.Info" OnClick="() => ShowStats(item)" />
                                    </MudTooltip>
                                    <MudTooltip Text="Bewerken">
                                        <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small"
                                                       Color="Color.Warning" OnClick="() => OpenEditDialog(item)" />
                                    </MudTooltip>
                                    <MudTooltip Text="Verwijderen">
                                        <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Size="Size.Small"
                                                       Color="Color.Error" OnClick="() => ConfirmDelete(item)" />
                                    </MudTooltip>
                                </MudStack>
                            </MudStack>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@* QR Code Dialog *@
@if (_showQrDialog)
{
    <MudOverlay Visible="@_showQrDialog" OnClick="CloseQrDialog" DarkBackground ZIndex="1300">
        <MudPaper Class="rounded-lg" Style="max-width: 480px; margin: auto; overflow: hidden;"
                  @onclick:stopPropagation="true" Elevation="8">
            <div class="pa-5">
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudText Typo="Typo.h6">@_selectedItem?.Title</MudText>
                    <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                   OnClick="CloseQrDialog" />
                </MudStack>
                <div style="background: repeating-conic-gradient(#ddd 0% 25%, #fff 0% 50%) 50% / 16px 16px; border-radius: 12px; padding: 1rem; display: flex; justify-content: center;">
                    @if (_qrImageData is not null)
                    {
                        <img src="data:image/png;base64,@Convert.ToBase64String(_qrImageData)" alt="QR Code"
                             style="width: 360px; height: 360px; border-radius: 8px;" />
                    }
                    else
                    {
                        <div style="width: 360px; height: 360px; display: flex; align-items: center; justify-content: center;">
                            <MudProgressCircular Indeterminate Color="Color.Primary" />
                        </div>
                    }
                </div>
            </div>
        </MudPaper>
    </MudOverlay>
}

@* Form Dialog *@
@if (_showFormDialog)
{
    <MudOverlay Visible="@_showFormDialog" OnClick="CloseFormDialog" DarkBackground ZIndex="1300">
        <MudPaper Class="rounded-lg" Style="max-width: 480px; margin: auto; min-width: 360px; overflow: hidden;"
                  @onclick:stopPropagation="true" Elevation="8">
            <div class="pa-5">
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudText Typo="Typo.h6">@(_isEditing ? "URL bewerken" : "Nieuwe URL")</MudText>
                    <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                   OnClick="CloseFormDialog" />
                </MudStack>
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_formTitle" Label="Titel" Required
                                  Variant="Variant.Outlined" Immediate />
                    <MudTextField @bind-Value="_formUrl" Label="Doel URL" Required
                                  Variant="Variant.Outlined" InputType="InputType.Url"
                                  Placeholder="https://voorbeeld.be" Immediate />
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">QR Code kleuren</MudText>
                    <MudGrid Spacing="2">
                        <MudItem xs="4">
                            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mb-1">Achtergrond</MudText>
                            <MudColorPicker @bind-Value="_formBackgroundColor" ColorPickerMode="ColorPickerMode.HEX"
                                            ShowAlpha="false" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mb-1">Voorgrond</MudText>
                            <MudColorPicker @bind-Value="_formForegroundColor" ColorPickerMode="ColorPickerMode.HEX"
                                            ShowAlpha="false" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mb-1">Finder</MudText>
                            <MudColorPicker @bind-Value="_formFinderColor" ColorPickerMode="ColorPickerMode.HEX"
                                            ShowAlpha="false" Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>
                    @if (_allTags.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Tags</MudText>
                        <MudChipSet T="Guid" SelectionMode="SelectionMode.MultiSelection" @bind-SelectedValues="_formSelectedTags">
                            @foreach (var tag in _allTags)
                            {
                                <MudChip T="Guid" Value="tag.Id"
                                         Variant="@(_formSelectedTags.Contains(tag.Id) ? Variant.Filled : Variant.Text)"
                                         Style="@(_formSelectedTags.Contains(tag.Id) ? $"background: {tag.Color}; color: white;" : $"border: 1px solid {tag.Color}; color: {tag.Color};")">
                                    @tag.Name
                                </MudChip>
                            }
                        </MudChipSet>
                    }
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Middenafbeelding (optioneel)</MudText>
                    @if (_formCenterImageData is not null)
                    {
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                            <div style="width: 48px; height: 48px; border-radius: 8px; overflow: hidden; border: 1px solid var(--mud-palette-lines-default); display: flex; align-items: center; justify-content: center;">
                                @if (_formCenterImageContentType == "image/svg+xml")
                                {
                                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                                        @((MarkupString)System.Text.Encoding.UTF8.GetString(_formCenterImageData))
                                    </div>
                                }
                                else
                                {
                                    <img src="data:@(_formCenterImageContentType);base64,@Convert.ToBase64String(_formCenterImageData)"
                                         alt="Middenafbeelding" style="max-width: 100%; max-height: 100%;" />
                                }
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="flex-grow-1">Afbeelding geselecteerd</MudText>
                            <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Size="Size.Small"
                                           Color="Color.Error" OnClick="RemoveCenterImage" />
                        </MudStack>
                    }
                    else
                    {
                        <MudFileUpload T="IBrowserFile" Accept=".png,.svg" FilesChanged="OnCenterImageSelected"
                                       MaximumFileCount="1">
                            <CustomContent>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Outlined.Image"
                                           Style="text-transform: none;"
                                           OnClick="@context.OpenFilePickerAsync">
                                    Afbeelding selecteren
                                </MudButton>
                            </CustomContent>
                            <SelectedTemplate Context="fileName"></SelectedTemplate>
                        </MudFileUpload>
                    }
                    @if (_formCenterImageData is not null && _formCenterImageContentType == "image/svg+xml")
                    {
                        <MudGrid Spacing="2">
                            <MudItem xs="4">
                                <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mb-1">Afbeeldingskleur</MudText>
                                <MudColorPicker @bind-Value="_formImageColor" ColorPickerMode="ColorPickerMode.HEX"
                                                ShowAlpha="false" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                    }
                </MudStack>
                <MudStack Row Justify="Justify.FlexEnd" Class="mt-5" Spacing="2">
                    <MudButton OnClick="CloseFormDialog" Style="text-transform: none;">Annuleren</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveForm"
                               Style="text-transform: none; font-weight: 600;"
                               Disabled="@(string.IsNullOrWhiteSpace(_formTitle) || string.IsNullOrWhiteSpace(_formUrl))">
                        @(_isEditing ? "Opslaan" : "Aanmaken")
                    </MudButton>
                </MudStack>
            </div>
        </MudPaper>
    </MudOverlay>
}

@* Stats Dialog *@
@if (_showStatsDialog)
{
    <MudOverlay Visible="@_showStatsDialog" OnClick="CloseStatsDialog" DarkBackground ZIndex="1300">
        <MudPaper Class="rounded-lg" Style="max-width: 800px; width: 90vw; margin: auto; overflow: hidden;"
                  @onclick:stopPropagation="true" Elevation="8">
            <div class="pa-5">
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6">@_selectedItem?.Title</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">Statistieken</MudText>
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                   OnClick="CloseStatsDialog" />
                </MudStack>
                @if (_statsLoading)
                {
                    <MudProgressLinear Indeterminate Color="Color.Primary" Class="rounded-lg" />
                }
                else if (_visitStats is not null)
                {
                    <MudPaper Elevation="0" Class="pa-4 rounded-lg mb-4"
                              Style="background: linear-gradient(135deg, #6366f1, #818cf8); color: white;">
                        <MudText Typo="Typo.caption" Style="opacity: 0.85;">TOTALE BEZOEKEN</MudText>
                        <MudText Typo="Typo.h3" Style="font-weight: 700;">@_visitStats.TotalVisits</MudText>
                    </MudPaper>
                    <MudTabs Elevation="0" Rounded ApplyEffectsToContainer>
                        <MudTabPanel Text="30 dagen">
                            <div class="pt-3">
                                <ApexChart TItem="VisitDataPoint" Height="280">
                                    <ApexPointSeries TItem="VisitDataPoint"
                                                     Items="_visitStats.DailyVisits"
                                                     SeriesType="SeriesType.Area"
                                                     Name="Bezoeken"
                                                     XValue="@(p => p.Date.ToString("dd/MM"))"
                                                     YValue="@(p => p.Count)" />
                                </ApexChart>
                            </div>
                        </MudTabPanel>
                        <MudTabPanel Text="12 weken">
                            <div class="pt-3">
                                <ApexChart TItem="VisitDataPoint" Height="280">
                                    <ApexPointSeries TItem="VisitDataPoint"
                                                     Items="_visitStats.WeeklyVisits"
                                                     SeriesType="SeriesType.Bar"
                                                     Name="Bezoeken"
                                                     XValue="@(p => $"W {p.Date:dd/MM}")"
                                                     YValue="@(p => p.Count)" />
                                </ApexChart>
                            </div>
                        </MudTabPanel>
                        <MudTabPanel Text="12 maanden">
                            <div class="pt-3">
                                <ApexChart TItem="VisitDataPoint" Height="280">
                                    <ApexPointSeries TItem="VisitDataPoint"
                                                     Items="_visitStats.MonthlyVisits"
                                                     SeriesType="SeriesType.Bar"
                                                     Name="Bezoeken"
                                                     XValue="@(p => p.Date.ToString("MMM yy"))"
                                                     YValue="@(p => p.Count)" />
                                </ApexChart>
                            </div>
                        </MudTabPanel>
                    </MudTabs>
                }
            </div>
        </MudPaper>
    </MudOverlay>
}

@code {
    private List<ShortUrlDto> _shortUrls = [];
    private List<TagDto> _allTags = [];
    private IReadOnlyCollection<Guid> _selectedFilterTags = [];
    private bool _loading = true;

    private bool _showQrDialog;
    private ShortUrlDto? _selectedItem;
    private byte[]? _qrImageData;

    private bool _showStatsDialog;
    private bool _statsLoading;
    private GetVisitStatsResponse? _visitStats;

    private bool _showFormDialog;
    private bool _isEditing;
    private Guid _editingId;
    private string _formTitle = string.Empty;
    private string _formUrl = string.Empty;
    private MudColor _formBackgroundColor = new("#FFFFFF");
    private MudColor _formForegroundColor = new("#212121");
    private MudColor _formFinderColor = new("#212121");
    private IReadOnlyCollection<Guid> _formSelectedTags = [];
    private byte[]? _formCenterImageData;
    private string? _formCenterImageContentType;
    private MudColor _formImageColor = new("#212121");
    private bool _formRemoveCenterImage;

    private List<ShortUrlDto> _filteredUrls =>
        _selectedFilterTags.Count == 0
            ? _shortUrls
            : _shortUrls.Where(u => u.Tags.Any(t => _selectedFilterTags.Contains(t.Id))).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _shortUrls = (await Mediator.Send(new GetShortUrlsQuery())).ShortUrls;
        _allTags = (await Mediator.Send(new GetTagsQuery())).Tags;
        _loading = false;
    }

    private void OpenCreateDialog()
    {
        _isEditing = false;
        _formTitle = string.Empty;
        _formUrl = string.Empty;
        _formBackgroundColor = new("#FFFFFF");
        _formForegroundColor = new("#212121");
        _formFinderColor = new("#212121");
        _formSelectedTags = [];
        _formCenterImageData = null;
        _formCenterImageContentType = null;
        _formImageColor = new("#212121");
        _formRemoveCenterImage = false;
        _showFormDialog = true;
    }

    private async Task OpenEditDialog(ShortUrlDto item)
    {
        _isEditing = true;
        _editingId = item.Id;
        _formTitle = item.Title;
        _formUrl = item.OriginalUrl;
        _formBackgroundColor = new(item.BackgroundColor);
        _formForegroundColor = new(item.ForegroundColor);
        _formFinderColor = new(item.FinderPatternColor);
        _formSelectedTags = item.Tags.Select(t => t.Id).ToList();
        _formImageColor = new(item.CenterImageColor ?? "#212121");
        _formRemoveCenterImage = false;

        if (item.HasCenterImage)
        {
            var centerImage = await Mediator.Send(new GetCenterImageQuery { ShortUrlId = item.Id });
            _formCenterImageData = centerImage?.ImageData;
            _formCenterImageContentType = centerImage?.ContentType ?? "image/png";
        }
        else
        {
            _formCenterImageData = null;
            _formCenterImageContentType = null;
        }

        _showFormDialog = true;
    }

    private void CloseFormDialog() => _showFormDialog = false;

    private async Task SaveForm()
    {
        if (string.IsNullOrWhiteSpace(_formTitle) || string.IsNullOrWhiteSpace(_formUrl)) return;

        if (_isEditing)
        {
            await Mediator.Send(new UpdateShortUrlCommand
            {
                Id = _editingId,
                Title = _formTitle,
                OriginalUrl = _formUrl,
                BackgroundColor = _formBackgroundColor.ToString(MudColorOutputFormats.Hex),
                ForegroundColor = _formForegroundColor.ToString(MudColorOutputFormats.Hex),
                FinderPatternColor = _formFinderColor.ToString(MudColorOutputFormats.Hex),
                TagIds = _formSelectedTags.ToList(),
                CenterImageData = _formCenterImageData,
                CenterImageContentType = _formCenterImageContentType,
                CenterImageColor = _formCenterImageContentType == "image/svg+xml" ? _formImageColor.ToString(MudColorOutputFormats.Hex) : null,
                RemoveCenterImage = _formRemoveCenterImage
            });
            Snackbar.Add("URL bijgewerkt!", Severity.Success);
        }
        else
        {
            await Mediator.Send(new CreateShortUrlCommand
            {
                Title = _formTitle,
                OriginalUrl = _formUrl,
                BackgroundColor = _formBackgroundColor.ToString(MudColorOutputFormats.Hex),
                ForegroundColor = _formForegroundColor.ToString(MudColorOutputFormats.Hex),
                FinderPatternColor = _formFinderColor.ToString(MudColorOutputFormats.Hex),
                TagIds = _formSelectedTags.ToList(),
                CenterImageData = _formCenterImageData,
                CenterImageContentType = _formCenterImageContentType,
                CenterImageColor = _formCenterImageContentType == "image/svg+xml" ? _formImageColor.ToString(MudColorOutputFormats.Hex) : null
            });
            Snackbar.Add("URL aangemaakt!", Severity.Success);
        }

        _showFormDialog = false;
        await LoadData();
    }

    private async Task ConfirmDelete(ShortUrlDto item)
    {
        var parameters = new DialogParameters<MessageBoxDialog>
        {
            { x => x.ContentText, $"Weet je zeker dat je '{item.Title}' wilt verwijderen?" },
            { x => x.YesText, "Verwijderen" },
            { x => x.CancelText, "Annuleren" }
        };

        var dialog = await DialogService.ShowAsync<MessageBoxDialog>("Verwijderen", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await Mediator.Send(new DeleteShortUrlCommand { Id = item.Id });
            Snackbar.Add("URL verwijderd!", Severity.Success);
            await LoadData();
        }
    }

    private async Task ShowQrCode(ShortUrlDto item)
    {
        _selectedItem = item;
        _qrImageData = null;
        _showQrDialog = true;

        byte[]? centerImage = null;
        if (item.HasCenterImage)
        {
            var ci = await Mediator.Send(new GetCenterImageQuery { ShortUrlId = item.Id });
            centerImage = ci?.ImageData;
        }

        var response = await Mediator.Send(new GetQrCodeQuery
        {
            Url = $"{NavigationManager.BaseUri}r/{item.ShortCode}",
            BackgroundColor = item.BackgroundColor,
            ForegroundColor = item.ForegroundColor,
            FinderPatternColor = item.FinderPatternColor,
            CenterImageData = centerImage,
            CenterImageColor = item.CenterImageColor
        });
        _qrImageData = response.ImageData;
        StateHasChanged();
    }

    private void CloseQrDialog()
    {
        _showQrDialog = false;
        _qrImageData = null;
    }

    private async Task ShowStats(ShortUrlDto item)
    {
        _selectedItem = item;
        _visitStats = null;
        _statsLoading = true;
        _showStatsDialog = true;

        _visitStats = await Mediator.Send(new GetVisitStatsQuery { ShortUrlId = item.Id });
        _statsLoading = false;
        StateHasChanged();
    }

    private void CloseStatsDialog()
    {
        _showStatsDialog = false;
        _visitStats = null;
    }

    private void OnFilterChanged(IReadOnlyCollection<Guid> values)
    {
        _selectedFilterTags = values;
    }

    private async Task OnCenterImageSelected(IBrowserFile file)
    {
        using var stream = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 1024 * 1024).CopyToAsync(stream);
        _formCenterImageData = stream.ToArray();
        _formCenterImageContentType = file.Name.EndsWith(".svg", StringComparison.OrdinalIgnoreCase)
            ? "image/svg+xml"
            : "image/png";
        _formRemoveCenterImage = false;
    }

    private void RemoveCenterImage()
    {
        _formCenterImageData = null;
        _formCenterImageContentType = null;
        _formRemoveCenterImage = true;
    }
}
