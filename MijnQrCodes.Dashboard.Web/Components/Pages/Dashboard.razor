@page "/"
@using MediatR
@using MijnQrCodes.Contracts.Dashboard
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IMediator Mediator

<PageTitle>Dashboard - MijnQrCodes</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary" />
    }
    else if (_stats is not null)
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Link" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.h3" Class="mt-2">@_stats.TotalLinks</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Tertiary">Totale links</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.TouchApp" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h3" Class="mt-2">@_stats.TotalClicks</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Tertiary">Totale kliks</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h3" Class="mt-2">@_stats.ClicksToday</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Tertiary">Kliks vandaag</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.DateRange" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h3" Class="mt-2">@_stats.ClicksThisWeek</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Tertiary">Kliks deze week</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h3" Class="mt-2">@_stats.ClicksThisMonth</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Tertiary">Kliks deze maand</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Celebration" Color="Color.Error" Size="Size.Large" />
                    <MudText Typo="Typo.h3" Class="mt-2">@_stats.ClicksThisYear</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Tertiary">Kliks dit jaar</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="4" Class="mt-4">
            <MudItem xs="12" md="7">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Class="mr-1" />
                        Top 5 links
                    </MudText>
                    @if (_stats.TopLinks.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Tertiary">Nog geen kliks geregistreerd.</MudText>
                    }
                    else
                    {
                        <MudSimpleTable Hover Dense>
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Titel</th>
                                    <th>Code</th>
                                    <th style="text-align: right;">Kliks</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < _stats.TopLinks.Count; i++)
                                {
                                    var link = _stats.TopLinks[i];
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>@link.Title</td>
                                        <td><MudLink Href="@($"/urls")" Color="Color.Primary">/@link.ShortCode</MudLink></td>
                                        <td style="text-align: right;"><strong>@link.Clicks</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="5">
                <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center justify-center" Style="height: 100%; min-height: 200px;">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h6" Class="mt-2">Beste dag van de week</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary" Class="mt-1">@_stats.BestDayOfWeek</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Tertiary">@_stats.BestDayOfWeekClicks kliks</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private bool _loading = true;
    private GetDashboardStatsResponse? _stats;

    protected override async Task OnInitializedAsync()
    {
        _stats = await Mediator.Send(new GetDashboardStatsQuery());
        _loading = false;
    }
}
