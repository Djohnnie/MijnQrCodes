@page "/users"
@using MediatR
@using MijnQrCodes.Contracts.Auth
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Gebruikers - MijnQrCodes</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudText Typo="Typo.h4" Class="mb-6">Gebruikers</MudText>

    @if (_loading)
    {
        <MudStack Spacing="2">
            @for (var i = 0; i < 4; i++)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="72px" Class="rounded-lg" />
            }
        </MudStack>
    }
    else
    {
        <MudPaper Elevation="0" Class="rounded-lg" Style="border: 1px solid var(--mud-palette-lines-default); overflow: hidden;">
            <MudTable Items="_users" Hover Dense="false" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Gebruiker</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Aangemaakt</MudTh>
                    <MudTh Style="text-align: right;">Acties</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Gebruiker">
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                            <MudAvatar Size="Size.Small"
                                       Style="@($"background: {GetAvatarColor(context.Username)}; color: white; font-weight: 600; font-size: 0.75rem;")">
                                @context.Username[..1].ToUpper()
                            </MudAvatar>
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Username</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudStack Row Spacing="1">
                            @if (context.IsApproved)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                                         Style="font-weight: 500;">
                                    Goedgekeurd
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text"
                                         Style="font-weight: 500;">
                                    Wachtend
                                </MudChip>
                            }
                            @if (context.MustChangePassword)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text"
                                         Style="font-weight: 500;">
                                    Reset
                                </MudChip>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Aangemaakt">
                        <MudText Typo="Typo.body2" Color="Color.Tertiary">
                            @context.CreatedAt.ToString("dd MMM yyyy")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Acties" Style="text-align: right;">
                        <MudStack Row Spacing="1" Justify="Justify.FlexEnd">
                            @if (!context.IsApproved)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                           StartIcon="@Icons.Material.Outlined.Check"
                                           Style="text-transform: none; font-weight: 600;"
                                           OnClick="() => ApproveUser(context)">
                                    Goedkeuren
                                </MudButton>
                            }
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                       StartIcon="@Icons.Material.Outlined.LockReset"
                                       Style="text-transform: none;"
                                       OnClick="() => ResetPassword(context)">
                                Reset
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

@if (_showTempPasswordDialog)
{
    <MudOverlay Visible="@_showTempPasswordDialog" OnClick="() => _showTempPasswordDialog = false" DarkBackground ZIndex="1300">
        <MudPaper Class="rounded-lg" Style="max-width: 420px; margin: auto; overflow: hidden;"
                  @onclick:stopPropagation="true" Elevation="8">
            <div class="pa-5">
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudText Typo="Typo.h6">Tijdelijk wachtwoord</MudText>
                    <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                   OnClick="() => _showTempPasswordDialog = false" />
                </MudStack>
                <MudText Class="mb-3">
                    Het wachtwoord van <strong>@_resetUsername</strong> is gereset.
                </MudText>
                <MudTextField Value="@_tempPassword" ReadOnly Variant="Variant.Outlined" Label="Tijdelijk wachtwoord"
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.ContentCopy" />
                <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Dense Class="mt-3"
                          Style="font-size: 0.8rem;">
                    De gebruiker moet dit wachtwoord wijzigen bij het volgende aanmelden.
                </MudAlert>
            </div>
        </MudPaper>
    </MudOverlay>
}

@code {
    private List<UserDto> _users = [];
    private bool _loading = true;

    private bool _showTempPasswordDialog;
    private string _tempPassword = string.Empty;
    private string _resetUsername = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        var response = await Mediator.Send(new GetUsersQuery());
        _users = response.Users;
        _loading = false;
    }

    private async Task ApproveUser(UserDto user)
    {
        await Mediator.Send(new ApproveUserCommand { UserId = user.Id });
        Snackbar.Add($"'{user.Username}' is goedgekeurd!", Severity.Success);
        await LoadUsers();
    }

    private async Task ResetPassword(UserDto user)
    {
        var parameters = new DialogParameters<MessageBoxDialog>
        {
            { x => x.ContentText, $"Weet je zeker dat je het wachtwoord van '{user.Username}' wilt resetten?" },
            { x => x.YesText, "Resetten" },
            { x => x.CancelText, "Annuleren" }
        };

        var dialog = await DialogService.ShowAsync<MessageBoxDialog>("Wachtwoord resetten", parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new ResetUserPasswordCommand { UserId = user.Id });

        if (result.Success)
        {
            _resetUsername = user.Username;
            _tempPassword = result.TemporaryPassword;
            _showTempPasswordDialog = true;
            await LoadUsers();
        }
        else
        {
            Snackbar.Add("Er is iets misgegaan.", Severity.Error);
        }
    }

    private static string GetAvatarColor(string name)
    {
        var colors = new[] { "#6366f1", "#8b5cf6", "#3b82f6", "#22c55e", "#f59e0b", "#ef4444", "#ec4899", "#14b8a6" };
        return colors[Math.Abs(name.GetHashCode()) % colors.Length];
    }
}
