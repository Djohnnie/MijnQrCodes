@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                               OnClick="ToggleDrawer" aria-label="Menu" />
            </Authorized>
        </AuthorizeView>
        <MudIcon Icon="@Icons.Material.Filled.QrCode2" Class="mr-2" />
        <MudText Typo="Typo.h6">MijnQrCodes</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleDarkMode" aria-label="Dark mode" />
    </MudAppBar>
    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always">
                <MudNavMenu>
                    <MudNavLink Href="/" Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                    <MudNavLink Href="/urls" Match="NavLinkMatch.Prefix"
                                Icon="@Icons.Material.Filled.Link">URL's</MudNavLink>
                    <MudNavLink Href="/users" Match="NavLinkMatch.Prefix"
                                Icon="@Icons.Material.Filled.People">Gebruikers</MudNavLink>
                </MudNavMenu>
                <MudSpacer />
                <MudNavMenu>
                    <MudNavLink Href="/logout" Icon="@Icons.Material.Filled.Logout">Afmelden</MudNavLink>
                </MudNavMenu>
            </MudDrawer>
        </Authorized>
    </AuthorizeView>
    <MudMainContent>
        <MudPopoverProvider />
        <MudDialogProvider />
        <MudSnackbarProvider />
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "darkMode");
            if (stored is not null)
            {
                _isDarkMode = stored == "true";
                StateHasChanged();
            }
        }
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", "darkMode", _isDarkMode.ToString().ToLower());
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
