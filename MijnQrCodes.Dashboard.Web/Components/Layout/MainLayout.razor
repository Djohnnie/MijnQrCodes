@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIcon Icon="@Icons.Material.Filled.QrCode2" Class="mr-2" />
        <MudText Typo="Typo.h6">MijnQrCodes</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudButton Href="/" Color="Color.Inherit" Variant="Variant.Text">URL's</MudButton>
                <MudButton Href="/users" Color="Color.Inherit" Variant="Variant.Text">Gebruikers</MudButton>
                <MudButton Href="/logout" Color="Color.Inherit" Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.Logout">Afmelden</MudButton>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    <MudMainContent Class="pt-16">
        @Body
    </MudMainContent>
</MudLayout>
