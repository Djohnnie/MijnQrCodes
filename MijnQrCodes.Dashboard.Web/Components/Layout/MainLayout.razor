@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<MudThemeProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                               OnClick="ToggleDrawer" aria-label="Menu" />
            </Authorized>
        </AuthorizeView>
        <MudIcon Icon="@Icons.Material.Filled.QrCode2" Class="mr-2" />
        <MudText Typo="Typo.h6">MijnQrCodes</MudText>
    </MudAppBar>
    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always">
                <MudNavMenu>
                    <MudNavLink Href="/" Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                    <MudNavLink Href="/urls" Match="NavLinkMatch.Prefix"
                                Icon="@Icons.Material.Filled.Link">URL's</MudNavLink>
                    <MudNavLink Href="/users" Match="NavLinkMatch.Prefix"
                                Icon="@Icons.Material.Filled.People">Gebruikers</MudNavLink>
                </MudNavMenu>
                <MudSpacer />
                <MudNavMenu>
                    <MudNavLink Href="/logout" Icon="@Icons.Material.Filled.Logout">Afmelden</MudNavLink>
                </MudNavMenu>
            </MudDrawer>
        </Authorized>
    </AuthorizeView>
    <MudMainContent>
        <MudPopoverProvider />
        <MudDialogProvider />
        <MudSnackbarProvider />
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
